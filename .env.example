DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: commands update instantly on this server while testing.
# Remove it later to deploy global commands.
DISCORD_GUILD_ID=your_test_server_id_here

# Optional: exact log channel ID. If empty, the bot searches for a channel with "логи" in the name.
DISCORD_LOG_CHANNEL_ID=

# Optional: keep true after turning on the same privileged intents in Discord Developer Portal.
DISCORD_ENABLE_MEMBER_LOGS=true
DISCORD_ENABLE_MESSAGE_CONTENT_LOGS=true
